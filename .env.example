# --- Postgres ---
# Local (matches docker-compose.yml). For prod use the Neon pooled connection string.
DATABASE_URL="postgresql://music:music@localhost:5432/music_social?schema=public"
# Direct (non-pooled) URL — required by Prisma for migrations.
# Locally: same as DATABASE_URL. On Vercel + Neon: auto-injected by the marketplace integration.
DATABASE_URL_UNPOOLED="postgresql://music:music@localhost:5432/music_social?schema=public"

# --- Auth.js ---
# Generate with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="replace-me"
# Public URL where the app is served. On Vercel, this is auto-set via VERCEL_URL — keep this only for local.
AUTH_URL="http://localhost:3000"
# Required on Vercel and behind any proxy/edge that rewrites the host header.
# AUTH_TRUST_HOST=true
